<%-include("layout/boilerplate")%>
<div class="card-container">
     <% for(student of students){%>
    <div class="card mycard">
  <img src="data:<%= student.image.contentType %>;base64,<%= student.image.data %>" class="card-img-top" alt="..." style="height:300px">
  <div class="card-body">
    <h5 class="card-title"><%=student.name%></h5>
    <div class="card-text">
        <p id="h">Email: <%=student.email%></p>
        <p>Course: <%=student.course%></p>
    </div>
    <a href="/student/<%=student._id%>" class="btn btn-primary">View</a>
    
  </div>
</div>
    <%}%>
</div>
    